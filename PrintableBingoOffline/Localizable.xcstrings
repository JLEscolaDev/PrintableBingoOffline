  "sourceLanguage" : "en",
  "strings" : {
    "%lld" : {
      "comment" : "The main content of the ball view, which is the number displayed in the center. The number is automatically extracted from the associated value of the view's containing view, `BallGrid`.",
      "isCommentAutoGenerated" : true
    },
    "%lld%%" : {
      "comment" : "A label showing the percentage of the time a joke will be played.",
      "isCommentAutoGenerated" : true
    },
    "%llds" : {
      "comment" : "A text view displaying the current value of the draw interval slider. The value is shown as an integer followed by a \"s\" suffix.",
      "isCommentAutoGenerated" : true
    },
    "75" : {
      "comment" : "A number option in the settings that allows the user to select a 75-number bingo game.",
      "isCommentAutoGenerated" : true
    },
